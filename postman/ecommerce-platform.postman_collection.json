{
  "info": {
    "name": "E-Commerce Platform API",
    "_postman_id": "ecommerce-platform-v1",
    "description": "Full API collection for the migrated e-commerce platform.\nRoutes through API Gateway (port 8080).\nBC References: BC-001 through BC-056.\n\nSetup:\n1. Import this collection and the environment file.\n2. Run 'Auth / Login' first — the accessToken is auto-saved to the environment.\n3. All protected requests automatically include the Bearer token.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [],
  "event": [],
  "item": [

    {
      "name": "Auth",
      "description": "Authentication endpoints (BC-034..042). All routes are PUBLIC — no JWT required.",
      "item": [

        {
          "name": "Register",
          "event": [],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/api/v1/auth/register", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","register"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"password\": \"Password1!\",\n  \"firstName\": \"New\",\n  \"lastName\": \"User\",\n  \"role\": \"CUSTOMER\"\n}"
            }
          },
          "response": []
        },

        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.accessToken) {",
                  "    pm.environment.set('accessToken', json.data.accessToken);",
                  "    pm.environment.set('refreshToken', json.data.refreshToken);",
                  "    console.log('Tokens saved to environment');",
                  "}",
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Access token present', () => pm.expect(json.data.accessToken).to.be.a('string'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","login"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
            }
          },
          "response": []
        },

        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.accessToken) {",
                  "    pm.environment.set('adminAccessToken', json.data.accessToken);",
                  "    pm.environment.set('adminRefreshToken', json.data.refreshToken);",
                  "    console.log('Admin tokens saved');",
                  "}",
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","login"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            }
          },
          "response": []
        },

        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.accessToken) {",
                  "    pm.environment.set('accessToken', json.data.accessToken);",
                  "}",
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/api/v1/auth/refresh-token", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","refresh-token"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          },
          "response": []
        },

        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/api/v1/auth/forgot-password", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","forgot-password"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\"\n}"
            }
          },
          "response": []
        },

        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/api/v1/auth/reset-password", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","reset-password"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{resetToken}}\",\n  \"newPassword\": \"NewPassword1!\"\n}"
            }
          },
          "response": []
        },

        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.environment.unset('accessToken');",
                  "pm.environment.unset('refreshToken');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/api/v1/auth/logout", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","logout"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          },
          "response": []
        }

      ]
    },

    {
      "name": "Customers",
      "description": "Customer management endpoints (BC-001..012). PROTECTED — requires Bearer token.",
      "auth": {
        "type": "bearer",
        "bearer": [{"key": "token", "value": "{{accessToken}}", "type": "string"}]
      },
      "item": [

        {
          "name": "Get Customer Summary by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('success is true', () => pm.expect(pm.response.json().success).to.be.true);",
                  "pm.test('customerNumber present', () => pm.expect(pm.response.json().data.customerNumber).to.be.a('string'));",
                  "// BC-005: B2C → wishlistVisible=true, businessAccountVisible=false",
                  "const data = pm.response.json().data;",
                  "if (data.customerType === 'B2C') {",
                  "    pm.test('BC-005: B2C wishlistVisible=true', () => pm.expect(data.wishlistVisible).to.be.true);",
                  "    pm.test('BC-005: B2C businessAccountVisible=false', () => pm.expect(data.businessAccountVisible).to.be.false);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/customers/{{customerId}}/summary",
              "host": ["{{baseUrl}}"],
              "path": ["api","v1","customers","{{customerId}}","summary"]
            }
          },
          "response": []
        },

        {
          "name": "Get Customer Summary by Number",
