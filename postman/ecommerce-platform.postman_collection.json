            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('data.content is array', () => pm.expect(pm.response.json().data.content).to.be.an('array'));"
