          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "const data = pm.response.json().data;",
                  "if (data && data.id) { pm.environment.set('catalogItemId', data.id); }",
                  "if (data && data.itemCode) { pm.environment.set('itemCode', data.itemCode); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/api/v1/catalog/items", "host": ["{{baseUrl}}"], "path": ["api","v1","catalog","items"]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"itemCode\": \"ITEM-{{$randomInt}}\",\n  \"name\": \"Test Widget\",\n  \"description\": \"A test widget\",\n  \"price\": 9.99,\n  \"active\": true\n}"
            }
          },
          "response": []
        },

        {
